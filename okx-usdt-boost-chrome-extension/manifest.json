{
  "manifest_version": 3,
  "name": "Boost & Alpha 交易助手",
  "version": "1.1.11",
  "description": "OKX Boost 与 Binance Alpha 的侧边栏交易工作台。",
  "icons": {
    "16": "icons/boost-alpha-16.png",
    "32": "icons/boost-alpha-32.png",
    "48": "icons/boost-alpha-48.png",
    "128": "icons/boost-alpha-128.png"
  },
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "sidePanel",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://web3.okx.com/*",
    "https://web3.cnouxyex.co/*",
    "https://www.binance.com/*"
  ],
  "action": {
    "default_title": "打开 Boost & Alpha 交易助手",
    "default_icon": {
      "16": "icons/boost-alpha-16.png",
      "32": "icons/boost-alpha-32.png",
      "48": "icons/boost-alpha-48.png",
      "128": "icons/boost-alpha-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web3.okx.com/*",
        "https://web3.cnouxyex.co/*"
      ],
      "js": [
        "page-engine.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://web3.okx.com/*",
        "https://web3.cnouxyex.co/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.binance.com/zh-CN/alpha/*"
      ],
      "js": [
        "alpha-page-engine.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.binance.com/zh-CN/alpha/*"
      ],
      "js": [
        "alpha-content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
